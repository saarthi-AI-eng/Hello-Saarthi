# Saarthi Backend - copy to .env and fill in values

# Server (frontend expects http://localhost:8000/api)
PORT=8000
HOST=0.0.0.0

# AI service (backend_api_docs.md)
AI_SERVICE_BASE_URL=https://api.saarthi.app/v1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/saarthi

# JWT (use strong secret in production)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
